{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "sql-practice-web",
  "main": "worker.ts",
  "compatibility_date": "2026-07-21",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  }
}
